{
  "name": "prato-feito-frontend",
  "packageManager": "bun@1.3.10",
  "description": "Interface web do PratoFeito, uma comunidade para compartilhar receitas testadas, achadinhos gastronômicos, dicas de cozinha e experiências reais com comida.",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun build ./src/index.html --outdir=dist --sourcemap --target=browser --minify --define:process.env.NODE_ENV='\"production\"' --env='BUN_PUBLIC_*'",
    "dev": "bun --hot src/index.ts",
    "start": "NODE_ENV=production bun src/index.ts",
    "biome:check": "bunx biome check ./src ./tests --error-on-warnings",
    "biome:write": "bunx biome check --write ./src ./tests",
    "prepare": "husky"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.2",
    "axios": "^1.18.1",
    "bun-react-template": ".",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router": "^8.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@commitlint/cli": "21.2.1",
    "@commitlint/config-conventional": "21.2.0",
    "@types/bun": "1.3.14",
    "@types/react": "19.2.17",
    "@types/react-dom": "19",
    "@types/react-router": "^5.1.20",
    "husky": "9.1.7"
  }
}
